// TransitOps - Prisma Schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// ENUMS

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  ACTIVE
  CLOSED
}

enum ExpenseType {
  TOLL
  MAINTENANCE
  OTHER
}

// MODELS


model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // If this user is also a driver, link to their driver profile
  driver               Driver?
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model Vehicle {
  id                 String        @id @default(uuid())
  registrationNumber String        @unique
  name               String        // model/name, e.g. "Van-05"
  type               String        // e.g. Van, Truck, Bike
  maxLoadCapacity    Float         // in kg
  odometer           Float         @default(0)
  acquisitionCost    Float
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  @@index([status])
  @@map("vehicles")
}

model Driver {
  id                String       @id @default(uuid())
  userId            String?      @unique
  user              User?        @relation(fields: [userId], references: [id])

  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Float        @default(100)
  status            DriverStatus @default(AVAILABLE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  trips             Trip[]

  @@index([status])
  @@map("drivers")
}

model Trip {
  id              String     @id @default(uuid())

  vehicleId       String
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])

  driverId        String
  driver          Driver     @relation(fields: [driverId], references: [id])

  source          String
  destination     String
  cargoWeight     Float      // must be <= vehicle.maxLoadCapacity, checked in app layer
  plannedDistance Float

  startOdometer   Float?
  endOdometer     Float?
  fuelConsumed    Float?     // liters, entered on completion

  status          TripStatus @default(DRAFT)

  dispatchedAt    DateTime?
  completedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  fuelLogs        FuelLog[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@map("trips")
}

model MaintenanceLog {
  id          String             @id @default(uuid())

  vehicleId   String
  vehicle     Vehicle            @relation(fields: [vehicleId], references: [id])

  description String             // e.g. "Oil Change"
  cost        Float              @default(0)
  status      MaintenanceStatus  @default(ACTIVE)

  createdAt   DateTime           @default(now())
  closedAt    DateTime?

  @@index([vehicleId])
  @@index([status])
  @@map("maintenance_logs")
}

model FuelLog {
  id       String   @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  tripId    String?
  trip      Trip?   @relation(fields: [tripId], references: [id])

  liters    Float
  cost      Float
  date      DateTime @default(now())

  @@index([vehicleId])
  @@map("fuel_logs")
}

model Expense {
  id          String      @id @default(uuid())

  vehicleId   String
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])

  type        ExpenseType
  amount      Float
  description String?
  date        DateTime    @default(now())

  @@index([vehicleId])
  @@map("expenses")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}
